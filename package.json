{
  "name": "claude-switch",
  "version": "1.0.0",
  "description": "Automatic Claude Code account switching on rate limits — works on macOS, Linux and Windows",
  "type": "module",
  "bin": {
    "claude-switch": "./bin/claude-switch.js"
  },
  "scripts": {
